generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ObjectivePerspective {
  FINANCIAL
  CUSTOMER
  INTERNAL_PROCESS
  LEARNING_GROWTH
}

enum ObjectiveStatus {
  ON_TRACK
  AT_RISK
  BLOCKED
}

enum KeyResultStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TargetDirection {
  INCREASE
  DECREASE
}

enum TaskSourceType {
  OKR
  OPERATIONAL
  SUPPORT
  AD_HOC
}

enum TaskType {
  ROUTINE
  INITIATIVE
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  BLOCKED
  CANCELLED
}

enum ContentType {
  VIDEO
  SINGLE_POST
  CAROUSEL
  ARTICLE
  THUMBNAIL
}

enum ContentStatus {
  IDEA
  PENDING
  PRODUCTION
  REVIEW
  REVISION
  APPROVED
  PUBLISHED
  CANCELLED
}


enum TimeBankStatus {
  SUBMITTED
  APPROVED
  REJECTED
}


enum EffortLevel {
  LOW
  MEDIUM
  HIGH
  DEEP_WORK
}

enum TaskComplexity {
  ROUTINE
  MODERATE
  STRATEGIC
}

enum TaskCategory {
  CREATIVE
  OPERATIONAL
  STRATEGIC
  ADMINISTRATIVE
}

enum AppreciationType {
  HELPFUL
  IMPACTFUL
  INITIATIVE
}


























model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id          String  @id @default(cuid())
  name        String  @unique
  code        String? @unique
  description String?
  active      Boolean @default(true)

  users          User[]
  keyResults     KeyResult[]
  tasks          Task[]
  retrospectives Retrospective[]
  contents       Content[]
  timeBankEntries TimeBankEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                  String     @id @default(cuid())
  roleId              String
  teamId              String?
  managerId           String?
  name                String
  email               String     @unique
  passwordHash        String?
  authProvider        String?
  employeeCode        String?    @unique
  joinDate            DateTime?
  status              UserStatus @default(ACTIVE)
  minDailyInputTarget Int        @default(1)
  avatarUrl           String?

  role              Role        @relation(fields: [roleId], references: [id], onDelete: Restrict)
  team              Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  manager           User?       @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates      User[]      @relation("UserManager")
  ownedObjectives   Objective[] @relation("ObjectiveOwner")
  createdObjectives Objective[] @relation("ObjectiveCreatedBy")
  ownedKeyResults   KeyResult[] @relation("KeyResultOwner")
  createdKeyResults KeyResult[] @relation("KeyResultCreatedBy")

  tasks             Task[]
  retrospectives    Retrospective[]
  requestedContents Content[]       @relation("ContentRequestor")
  assignedContents  Content[]       @relation("ContentAssignee")
  timeBankEntries        TimeBankEntry[] @relation("TimeBankUser")
  approvedTimeBankEntries TimeBankEntry[] @relation("TimeBankApprovedBy")
  appreciationsGiven     Appreciation[] @relation("AppreciationFrom")
  appreciationsReceived  Appreciation[] @relation("AppreciationTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@index([teamId])
  @@index([managerId])
}

model Objective {
  id          String               @id @default(cuid())
  year        Int
  perspective ObjectivePerspective
  title       String
  description String?
  status      ObjectiveStatus      @default(ON_TRACK)
  ownerUserId String?
  createdById String

  owner     User? @relation("ObjectiveOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy User  @relation("ObjectiveCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  keyResults KeyResult[]
  tasks      Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([year])
  @@index([perspective])
  @@index([ownerUserId])
}

model KeyResult {
  id                 String          @id @default(cuid())
  objectiveId        String
  teamId             String
  ownerUserId        String
  year               Int
  quarter            Int
  title              String
  description        String?
  targetValue        Decimal         @db.Decimal(18, 4)
  currentValue       Decimal         @default(0) @db.Decimal(18, 4)
  unit               String
  targetDirection    TargetDirection
  progressPercentage Decimal?        @db.Decimal(7, 2)
  status             KeyResultStatus @default(NOT_STARTED)
  isActive           Boolean         @default(true)
  lastUpdatedAt      DateTime?
  createdById        String

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Restrict)
  owner     User      @relation("KeyResultOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  createdBy User      @relation("KeyResultCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([objectiveId])
  @@index([teamId])
  @@index([ownerUserId])
  @@index([year, quarter])
  @@index([status])
}

model Task {
  id          String         @id @default(cuid())
  userId      String
  teamId      String
  objectiveId String?
  keyResultId String?
  
  sourceType  TaskSourceType
  taskType    TaskType
  title       String
  description String?
  taskDate    DateTime
  status      TaskStatus     @default(NOT_STARTED)
  
  effortLevel         EffortLevel      @default(MEDIUM)
  complexity          TaskComplexity   @default(ROUTINE)
  durationMinutes     Int              @default(60)
  taskCategory        TaskCategory?
  isDeepWork          Boolean          @default(false)

  activityScore       Int              @default(1)
  contributionScore   Float            @default(0)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Restrict)
  objective Objective? @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  keyResult KeyResult? @relation(fields: [keyResultId], references: [id], onDelete: SetNull)
  appreciations          Appreciation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([objectiveId])
  @@index([keyResultId])
  @@index([status])
  @@index([taskDate])
}

model Retrospective {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  weekStart DateTime
  weekEnd   DateTime

  workSummary     Json
  keyResultImpact Json

  blockers String?
  insights String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([weekStart])
}

model Content {
  id          String        @id @default(cuid())
  title       String
  description String?
  contentType ContentType
  status      ContentStatus @default(IDEA)

  requestorId String
  assigneeId  String?
  teamId      String

  deadline    DateTime?
  publishDate DateTime?

  productionLink String?
  revisionNotes  String?

  requestor User  @relation("ContentRequestor", fields: [requestorId], references: [id])
  assignee  User? @relation("ContentAssignee", fields: [assigneeId], references: [id])
  team      Team  @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([teamId])
}


model TimeBankEntry {
  id              String         @id @default(cuid())
  userId          String
  teamId          String
  entryDate       DateTime
  durationMinutes Int
  reason          String
  notes           String?
  approvedById    String?
  status          TimeBankStatus @default(SUBMITTED)

  user            User           @relation("TimeBankUser", fields: [userId], references: [id], onDelete: Cascade)
  team            Team           @relation(fields: [teamId], references: [id], onDelete: Restrict)
  approvedBy      User?          @relation("TimeBankApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([entryDate])
  @@index([status])
}

model Appreciation {
  id         String           @id @default(cuid())
  fromUserId String
  toUserId   String
  taskId     String?
  message    String
  type       AppreciationType

  fromUser   User             @relation("AppreciationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User             @relation("AppreciationTo", fields: [toUserId], references: [id], onDelete: Cascade)
  task       Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([fromUserId])
  @@index([toUserId])
  @@index([taskId])
  @@index([createdAt])
}